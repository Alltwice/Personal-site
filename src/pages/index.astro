---
import BaseLayout from '../layouts/BaseLayout.astro';
import ShowcaseLayout from '../components/ShowcaseLayout.astro';
import ProfilePanel from '../components/ProfilePanel.astro';
import CurrentTime from '../components/CurrentTime.astro';
import ShowcaseVisual from '../components/ShowcaseVisual.astro';
import ScrollIndicator from '../components/ScrollIndicator.astro';
import DetailSection from '../components/DetailSection.astro';
import PostCard from '../components/PostCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getPostsByDate } from '../data/posts';
import { featuredProjects } from '../data/projects';

const latestPosts = getPostsByDate().slice(0, 3);
const homeProjects = featuredProjects.slice(0, 3);
---

<BaseLayout title="Personal Site | 首页" description="记录文章、项目与持续学习的个人站点。">
	<ShowcaseLayout pageLabel="Home" label="Index / 01" titleId="home-title" detailId="home-detail" variant="home">
		<ProfilePanel slot="profile" name="Kristen" variant="social" />

		<div slot="intro" class="showcase-copy">
			<p class="showcase-copy__kicker">Hello, this is my personal site.</p>
			<h1 id="home-title">记录想法，<br /><span>构建正在发生的事</span></h1>
			<p class="showcase-copy__lead">
			————以博客，个人项目为主构建的个人空间，保持整洁，留下生长的接口
			</p>
		</div>

		<ShowcaseVisual slot="visual" />

		<CurrentTime slot="meta" />

		<ScrollIndicator slot="indicator" target="home-detail" />
	</ShowcaseLayout>

	<div class="detail-stack" id="home-detail">
		<DetailSection id="introduction" number="01" label="Profile" title="个人介绍" description="这里是可替换的示例内容，用来说明这个站点正在记录什么。">
			<div class="split-copy">
				<p class="detail-lead">我关注设计与代码之间的距离，也在持续练习如何把模糊想法做成清晰、可使用的产品。</p>
				<p>这个站点将承载阶段性笔记、项目复盘和正在学习的主题。内容不追求一次完成，而是留下真实的迭代轨迹。</p>
			</div>
		</DetailSection>

		<DetailSection id="featured-articles" number="02" label="Articles" title="精选文章" description="从现有文章数据中选取最近发布的内容。">
			<div class="card-grid">{latestPosts.map((post) => <PostCard post={post} />)}</div>
			<a class="text-link" href="/blog">浏览全部文章 <span>View all</span></a>
		</DetailSection>

		<DetailSection id="featured-projects" number="03" label="Projects" title="精选项目" description="正在进行和准备继续完善的项目。">
			<div class="card-grid">{homeProjects.map((project) => <ProjectCard project={project} />)}</div>
			<a class="text-link" href="/projects">浏览全部项目 <span>View all</span></a>
		</DetailSection>

		<DetailSection id="learning" number="04" label="Learning" title="当前学习方向">
			<div class="learning-grid">
				<article><span>01</span><h3>内容架构</h3><p>让文章、项目与长期主题形成稳定关系。</p></article>
				<article><span>02</span><h3>前端表达</h3><p>用克制的动效和响应式布局改善阅读体验。</p></article>
				<article><span>03</span><h3>工作流</h3><p>把零散实验整理成可以重复使用的方法。</p></article>
			</div>
		</DetailSection>

		<DetailSection id="contact" number="05" label="Contact" title="联系方式" description="以下为示例字段，可替换为真实邮箱和社交账号。">
			<div class="contact-grid">
				<div><small>EMAIL</small><strong>your.name@example.com</strong></div>
				<div><small>SOCIAL</small><strong>@yourname</strong></div>
				<div><small>LOCATION</small><strong>Asia / Shanghai</strong></div>
			</div>
		</DetailSection>
	</div>
</BaseLayout>
