---
import BaseLayout from '../layouts/BaseLayout.astro';
import ShowcaseLayout from '../components/ShowcaseLayout.astro';
import ProfilePanel from '../components/ProfilePanel.astro';
import ShowcaseVisual from '../components/ShowcaseVisual.astro';
import ScrollIndicator from '../components/ScrollIndicator.astro';
import DetailSection from '../components/DetailSection.astro';
---

<BaseLayout title="关于 | Personal Site" description="个人背景、关注方向与联系方式。">
	<ShowcaseLayout pageLabel="About" label="Index / 04" titleId="about-title" detailId="about-detail" variant="about">
		<ProfilePanel slot="profile" name="Kristen" variant="social" />
		<div slot="intro" class="showcase-copy">
			<p class="showcase-copy__kicker">A small introduction.</p>
			<h1 id="about-title">关于<br /><span>在设计与代码之间工作。</span></h1>
			<p class="showcase-copy__lead">持续学习、持续制作，也持续整理做出每个选择的原因。</p>
		</div>
		<ShowcaseVisual slot="visual" alt="关于页面的蓝灰色线稿人物主视觉" />
		<div slot="meta" class="showcase-stat"><small>STATUS</small><strong>Open to ideas</strong><p>示例个人资料 · 等待替换为真实内容</p></div>
		<ScrollIndicator slot="indicator" target="about-detail" label="MORE" />
	</ShowcaseLayout>

	<div class="detail-stack" id="about-detail">
		<DetailSection id="background" number="01" label="Background" title="个人背景">
			<div class="split-copy"><p class="detail-lead">这是一个面向创作者与开发者的示例简介：关注清晰的信息结构、克制的视觉表达和真实可用的实现。</p><p>后续可以在这里替换教育、工作经历或转向当前领域的过程，不需要调整页面结构。</p></div>
		</DetailSection>
		<DetailSection id="directions" number="02" label="Direction" title="关注方向">
			<div class="learning-grid"><article><span>01</span><h3>Product thinking</h3><p>从真实问题出发组织功能与信息。</p></article><article><span>02</span><h3>Visual systems</h3><p>建立一致且能继续扩展的视觉语言。</p></article><article><span>03</span><h3>Frontend craft</h3><p>让布局、交互和内容在不同设备上可靠工作。</p></article></div>
		</DetailSection>
		<DetailSection id="about-contact" number="03" label="Contact" title="保持联系" description="示例字段，不连接到无效外部地址。">
			<div class="contact-grid"><div><small>EMAIL</small><strong>your.name@example.com</strong></div><div><small>SOCIAL</small><strong>@yourname</strong></div><div><small>TIMEZONE</small><strong>UTC +08:00</strong></div></div>
		</DetailSection>
	</div>
</BaseLayout>
