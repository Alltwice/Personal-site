---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShowcaseLayout from '../../components/ShowcaseLayout.astro';
import ProfilePanel from '../../components/ProfilePanel.astro';
import ShowcaseVisual from '../../components/ShowcaseVisual.astro';
import ScrollIndicator from '../../components/ScrollIndicator.astro';
import DetailSection from '../../components/DetailSection.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { projects, featuredProjects } from '../../data/projects';

const primaryProject = featuredProjects[0] ?? projects[0];
---

<BaseLayout title="项目 | Personal Site" description="个人站项目列表。">
	<ShowcaseLayout pageLabel="Projects" label="Index / 03" titleId="projects-title" detailId="projects-detail" variant="listing">
		<ProfilePanel slot="profile" name="PROJECT FILES" role={`${projects.length} active records`} status="Building in public" />
		<div slot="intro" class="showcase-copy">
			<p class="showcase-copy__kicker">Experiments becoming systems.</p>
			<h1 id="projects-title">项目<br /><span>把想法变成可见结果。</span></h1>
			<p class="showcase-copy__lead">这里保留目标、约束、选择和当前状态，而不只展示完成后的截图。</p>
		</div>
		<ShowcaseVisual slot="visual" alt="项目页面的蓝灰色线稿人物主视觉" />
		<div slot="meta" class="showcase-stat">
			<small>CURRENT FOCUS</small><strong>{primaryProject?.name}</strong><p>{featuredProjects.length} 个精选项目正在展示</p>
		</div>
		<ScrollIndicator slot="indicator" target="projects-detail" label="VIEW" />
	</ShowcaseLayout>

	<div class="detail-stack" id="projects-detail">
		<DetailSection id="project-archive" number="01" label="Work" title="全部项目" description="保留现有项目状态、标签和详情 slug。">
			<div class="project-list">{projects.map((project, index) => <ProjectCard project={project} data-index={index} />)}</div>
		</DetailSection>
	</div>
</BaseLayout>
