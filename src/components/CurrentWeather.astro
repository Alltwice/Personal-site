---
const tencentMapKey =
	import.meta.env.PUBLIC_TENCENT_MAP_KEY ?? '';
---

<section
	class="current-weather"
	aria-labelledby="weather-title"
	data-current-weather
	data-tencent-key={tencentMapKey}
	aria-busy="true"
>
	<div class="current-weather__heading">
		<p id="weather-title">
			Current location / Weather
		</p>

		<span data-weather-state>IP 定位中</span>
	</div>

	<div class="current-weather__location">
		<i
			class="ph ph-map-pin"
			aria-hidden="true"
		></i>

		<strong data-weather-location>
			正在获取位置
		</strong>
	</div>

	<div class="current-weather__summary">
		<i
			class="ph ph-cloud current-weather__icon"
			data-weather-icon
			aria-hidden="true"
		></i>

		<div>
			<strong>
				<span data-weather-temperature>--</span>
				<small>°C</small>
			</strong>

			<p data-weather-description>
				Loading weather
			</p>
		</div>
	</div>

	<div class="current-weather__range">
		<span>
			H:
			<strong data-weather-high>--°</strong>
		</span>

		<span>
			L:
			<strong data-weather-low>--°</strong>
		</span>
	</div>

	<div class="current-weather__footer">
		<button
			type="button"
			data-weather-retry
			hidden
		>
			重新加载
		</button>

		<span data-weather-updated>
			等待更新
		</span>
	</div>
</section>

<script>
	type TencentResponse<T> = {
		status: number;
		message?: string;
		result?: T;
	};

	type TencentIpLocationResult = {
		ip?: string;

		location?: {
			lat?: number;
			lng?: number;
		};

		ad_info?: {
			nation?: string;
			province?: string;
			city?: string;
			district?: string;
			adcode?: number | string;
		};
	};

	type IpLocationData = {
		ip: string;
		latitude: number | null;
		longitude: number | null;
		nation: string;
		province: string;
		city: string;
		district: string;
		adcode: string;
	};

	type RealtimeWeatherInfo = {
		weather?: string;
		temperature?: number;
		wind_direction?: string;
		wind_power?: string;
		wind_power_v2?: string;
		humidity?: number;
		air_pressure?: number;
	};

	type RealtimeWeatherItem = {
		province?: string;
		city?: string;
		district?: string;
		adcode?: number | string;
		update_time?: string;
		infos?: RealtimeWeatherInfo;
	};

	type ForecastPeriod = {
		weather?: string;
		temperature?: number;
		wind_direction?: string;
		wind_power?: string;
		humidity?: number;
	};

	type ForecastDayInfo = {
		date?: string;
		week?: string;
		day?: ForecastPeriod;
		night?: ForecastPeriod;
	};

	type ForecastWeatherItem = {
		province?: string;
		city?: string;
		district?: string;
		adcode?: number | string;
		update_time?: string;
		infos?: ForecastDayInfo[];
	};

	type TencentWeatherResult = {
		realtime?: RealtimeWeatherItem[];
		forecast?: ForecastWeatherItem[];
	};

	type CombinedWeatherData = {
		now: TencentWeatherResult;
		future: TencentWeatherResult;
		fetchedAt: number;
	};

	type CacheEnvelope<T> = {
		data: T;
		timestamp: number;
	};

	const API_BASE =
		'https://apis.map.qq.com/ws';

	/*
	 * 地区和天气缓存都为 1 小时。
	 */
	const CACHE_TTL =
		60 * 60 * 1000;

	const LOCATION_CACHE_KEY =
		'portfolio:tencent-ip-location:v1';

	const WEATHER_CACHE_PREFIX =
		'portfolio:tencent-weather:v1:';

	/*
	 * 避免连续请求触发频率限制。
	 */
	const REQUEST_GAP = 350;
	const RETRY_DELAY = 1500;
	const MAX_RETRIES = 2;

	let jsonpIndex = 0;

	let pendingLocation:
		| Promise<IpLocationData>
		| null = null;

	const pendingWeather =
		new Map<
			string,
			Promise<CombinedWeatherData>
		>();

	/**
	 * 延迟工具。
	 */
	function delay(milliseconds: number) {
		return new Promise<void>((resolve) => {
			window.setTimeout(resolve, milliseconds);
		});
	}

	/**
	 * 读取带过期时间的缓存。
	 */
	function readCache<T>(
		key: string,
		ttl: number
	): T | null {
		try {
			const raw =
				window.localStorage.getItem(key);

			if (!raw) {
				return null;
			}

			const cached =
				JSON.parse(raw) as CacheEnvelope<T>;

			if (
				typeof cached.timestamp !== 'number' ||
				Date.now() - cached.timestamp > ttl
			) {
				window.localStorage.removeItem(key);
				return null;
			}

			return cached.data;
		} catch (error) {
			console.warn(
				`读取缓存失败：${key}`,
				error
			);

			return null;
		}
	}

	/**
	 * 写入缓存。
	 */
	function writeCache<T>(
		key: string,
		data: T
	) {
		try {
			const cached: CacheEnvelope<T> = {
				data,
				timestamp: Date.now(),
			};

			window.localStorage.setItem(
				key,
				JSON.stringify(cached)
			);
		} catch (error) {
			console.warn(
				`写入缓存失败：${key}`,
				error
			);
		}
	}

	/**
	 * 清除所有腾讯天气缓存。
	 */
	function clearWeatherCaches() {
		try {
			for (
				let index =
					window.localStorage.length - 1;
				index >= 0;
				index -= 1
			) {
				const key =
					window.localStorage.key(index);

				if (
					key?.startsWith(
						WEATHER_CACHE_PREFIX
					)
				) {
					window.localStorage.removeItem(key);
				}
			}
		} catch (error) {
			console.warn(
				'清除天气缓存失败：',
				error
			);
		}
	}

	/**
	 * 为每个行政区生成独立天气缓存键。
	 */
	function getWeatherCacheKey(
		adcode: string
	) {
		return `${WEATHER_CACHE_PREFIX}${adcode}`;
	}

	/**
	 * JSONP 请求。
	 *
	 * 腾讯 WebService 支持 JSONP，
	 * 因此浏览器端不需要额外处理 CORS。
	 */
	function jsonp<T>(
		url: string,
		timeout = 10000
	): Promise<T> {
		return new Promise<T>(
			(resolve, reject) => {
				const callbackName =
					`__tencent_weather_callback_${Date.now()}_${++jsonpIndex}`;

				const callbackHost =
					window as unknown as Record<
						string,
						| ((data: unknown) => void)
						| undefined
					>;

				const script =
					document.createElement('script');

				let completed = false;

				const cleanup = () => {
					window.clearTimeout(timer);

					delete callbackHost[
						callbackName
					];

					script.remove();
				};

				const fail = (error: Error) => {
					if (completed) {
						return;
					}

					completed = true;
					cleanup();
					reject(error);
				};

				const timer =
					window.setTimeout(() => {
						fail(
							new Error(
								'腾讯位置服务请求超时'
							)
						);
					}, timeout);

				callbackHost[callbackName] = (
					data: unknown
				) => {
					if (completed) {
						return;
					}

					completed = true;
					cleanup();
					resolve(data as T);
				};

				script.async = true;

				const separator =
					url.includes('?') ? '&' : '?';

				script.src =
					`${url}${separator}` +
					`callback=${encodeURIComponent(
						callbackName
					)}`;

				script.onerror = () => {
					fail(
						new Error(
							'腾讯位置服务网络请求失败'
						)
					);
				};

				document.head.appendChild(script);
			}
		);
	}

	/**
	 * 判断腾讯接口错误是否适合重试。
	 */
	function isRetryableStatus(
		status: number
	) {
		return (
			status === 120 ||
			status === 500 ||
			status === 510 ||
			status === 520 ||
			status === 530 ||
			status === 531
		);
	}

	/**
	 * 统一调用腾讯 WebService。
	 */
	async function requestTencent<T>(
		key: string,
		path: string,
		parameters: Record<string, string>,
		maxRetries = MAX_RETRIES
	): Promise<T> {
		let retryCount = 0;

		while (true) {
			const searchParameters =
				new URLSearchParams({
					...parameters,
					key,
					output: 'jsonp',
				});

			const response =
				await jsonp<TencentResponse<T>>(
					`${API_BASE}${path}?${searchParameters}`
				);

			if (
				response.status === 0 &&
				response.result !== undefined
			) {
				return response.result;
			}

			if (
				isRetryableStatus(response.status) &&
				retryCount < maxRetries
			) {
				retryCount += 1;
				await delay(RETRY_DELAY);
				continue;
			}

			throw new Error(
				response.message ||
					`腾讯位置服务请求失败，状态码：${response.status}`
			);
		}
	}

	/**
	 * 获取腾讯 IP 定位。
	 *
	 * 不传 ip 参数时，腾讯会使用当前请求的公网 IP。
	 */
	async function requestIpLocation(
		key: string
	): Promise<IpLocationData> {
		const result =
			await requestTencent<TencentIpLocationResult>(
				key,
				'/location/v1/ip',
				{}
			);

		const adcode =
			result.ad_info?.adcode;

		if (
			adcode === undefined ||
			adcode === null ||
			String(adcode).trim() === ''
		) {
			throw new Error(
				'腾讯 IP 定位未返回有效行政区'
			);
		}

		return {
			ip: result.ip ?? '',
			latitude:
				typeof result.location?.lat ===
				'number'
					? result.location.lat
					: null,
			longitude:
				typeof result.location?.lng ===
				'number'
					? result.location.lng
					: null,
			nation:
				result.ad_info?.nation ?? '',
			province:
				result.ad_info?.province ?? '',
			city:
				result.ad_info?.city ?? '',
			district:
				result.ad_info?.district ?? '',
			adcode: String(adcode),
		};
	}

	/**
	 * 获取地区。
	 */
	async function getIpLocation(
		key: string,
		forceRefresh = false
	): Promise<IpLocationData> {
		if (!forceRefresh) {
			const cached =
				readCache<IpLocationData>(
					LOCATION_CACHE_KEY,
					CACHE_TTL
				);

			if (cached) {
				return cached;
			}
		}

		if (
			pendingLocation &&
			!forceRefresh
		) {
			return pendingLocation;
		}

		pendingLocation =
			requestIpLocation(key)
				.then((locationData) => {
					writeCache(
						LOCATION_CACHE_KEY,
						locationData
					);

					return locationData;
				})
				.finally(() => {
					pendingLocation = null;
				});

		return pendingLocation;
	}

	/**
	 * 根据行政区代码获取实时天气和未来天气。
	 *
	 * 实时请求负责当前温度；
	 * 未来请求负责今日最高温和最低温。
	 */
	async function requestWeather(
		key: string,
		adcode: string
	): Promise<CombinedWeatherData> {
		const now =
			await requestTencent<TencentWeatherResult>(
				key,
				'/weather/v1/',
				{
					adcode,
					type: 'now',
				}
			);

		await delay(REQUEST_GAP);

		const future =
			await requestTencent<TencentWeatherResult>(
				key,
				'/weather/v1/',
				{
					adcode,
					type: 'future',
					get_md: '0',
				}
			);

		return {
			now,
			future,
			fetchedAt: Date.now(),
		};
	}

	/**
	 * 获取天气，按行政区代码分别缓存。
	 */
	async function getWeather(
		key: string,
		adcode: string,
		forceRefresh = false
	): Promise<CombinedWeatherData> {
		const cacheKey =
			getWeatherCacheKey(adcode);

		if (!forceRefresh) {
			const cached =
				readCache<CombinedWeatherData>(
					cacheKey,
					CACHE_TTL
				);

			if (cached) {
				return cached;
			}
		}

		const existingRequest =
			pendingWeather.get(adcode);

		if (
			existingRequest &&
			!forceRefresh
		) {
			return existingRequest;
		}

		const request =
			requestWeather(key, adcode)
				.then((weatherData) => {
					writeCache(
						cacheKey,
						weatherData
					);

					return weatherData;
				})
				.finally(() => {
					pendingWeather.delete(adcode);
				});

		pendingWeather.set(adcode, request);

		return request;
	}

	/**
	 * 根据天气描述选择 Phosphor 图标。
	 */
	function getWeatherIcon(
		weather = ''
	) {
		const hour = new Date().getHours();
		const isNight =
			hour >= 18 || hour < 6;

		if (weather.includes('雷')) {
			return 'ph-cloud-lightning';
		}

		if (
			weather.includes('雨夹雪') ||
			weather.includes('冻雨')
		) {
			return 'ph-cloud-snow';
		}

		if (weather.includes('雪')) {
			return 'ph-cloud-snow';
		}

		if (weather.includes('雨')) {
			return 'ph-cloud-rain';
		}

		if (
			weather.includes('雾') ||
			weather.includes('霾')
		) {
			return 'ph-cloud-fog';
		}

		if (
			weather.includes('沙尘') ||
			weather.includes('浮尘') ||
			weather.includes('扬沙')
		) {
			return 'ph-wind';
		}

		if (weather.includes('晴')) {
			return isNight
				? 'ph-moon-stars'
				: 'ph-sun';
		}

		if (weather.includes('多云')) {
			return isNight
				? 'ph-cloud-moon'
				: 'ph-cloud-sun';
		}

		if (weather.includes('阴')) {
			return 'ph-cloud';
		}

		return 'ph-cloud';
	}

	/**
	 * 生成“省 · 市 · 区”显示文字。
	 */
	function formatLocation(
		locationData: IpLocationData
	) {
		const parts = [
			locationData.province,
			locationData.city,
			locationData.district,
		]
			.map((part) => part.trim())
			.filter(
				(part) => part.length > 0
			);

		return [...new Set(parts)].join(' · ') ||
			locationData.nation ||
			'位置未知';
	}

	/**
	 * 读取今日最高温和最低温。
	 */
	function getTemperatureRange(
		future: TencentWeatherResult
	) {
		const today =
			future.forecast?.[0]?.infos?.[0];

		const temperatures = [
			today?.day?.temperature,
			today?.night?.temperature,
		].filter(
			(value): value is number =>
				typeof value === 'number'
		);

		if (temperatures.length === 0) {
			return {
				high: null,
				low: null,
			};
		}

		return {
			high: Math.max(...temperatures),
			low: Math.min(...temperatures),
		};
	}

	/**
	 * 格式化更新时间。
	 */
	function formatUpdatedTime(
		value?: string | number
	) {
		if (typeof value === 'string') {
			const matched =
				value.match(
					/(\d{1,2}):(\d{2})/
				);

			if (matched) {
				return `${matched[1].padStart(
					2,
					'0'
				)}:${matched[2]}`;
			}
		}

		const date =
			typeof value === 'number'
				? new Date(value)
				: new Date();

		return new Intl.DateTimeFormat(
			'zh-CN',
			{
				hour: '2-digit',
				minute: '2-digit',
				hour12: false,
			}
		).format(date);
	}

	/**
	 * 初始化所有天气面板。
	 */
	function initializeWeatherPanels() {
		document
			.querySelectorAll<HTMLElement>(
				'[data-current-weather]'
			)
			.forEach((panel) => {
				if (
					panel.dataset
						.weatherInitialized ===
					'true'
				) {
					return;
				}

				panel.dataset.weatherInitialized =
					'true';

				const key =
					panel.dataset.tencentKey?.trim() ??
					'';

				const state =
					panel.querySelector<HTMLElement>(
						'[data-weather-state]'
					);

				const location =
					panel.querySelector<HTMLElement>(
						'[data-weather-location]'
					);

				const temperature =
					panel.querySelector<HTMLElement>(
						'[data-weather-temperature]'
					);

				const description =
					panel.querySelector<HTMLElement>(
						'[data-weather-description]'
					);

				const icon =
					panel.querySelector<HTMLElement>(
						'[data-weather-icon]'
					);

				const high =
					panel.querySelector<HTMLElement>(
						'[data-weather-high]'
					);

				const low =
					panel.querySelector<HTMLElement>(
						'[data-weather-low]'
					);

				const updated =
					panel.querySelector<HTMLElement>(
						'[data-weather-updated]'
					);

				const retry =
					panel.querySelector<HTMLButtonElement>(
						'[data-weather-retry]'
					);

				function resetView() {
					panel.setAttribute(
						'aria-busy',
						'true'
					);

					if (state) {
						state.textContent =
							'IP 定位中';
					}

					if (location) {
						location.textContent =
							'正在获取位置';
					}

					if (temperature) {
						temperature.textContent =
							'--';
					}

					if (description) {
						description.textContent =
							'Loading weather';
					}

					if (icon) {
						icon.className =
							'ph ph-cloud current-weather__icon';
					}

					if (high) {
						high.textContent = '--°';
					}

					if (low) {
						low.textContent = '--°';
					}

					if (updated) {
						updated.textContent =
							'等待更新';
					}

					if (retry) {
						retry.hidden = true;
					}
				}

				function renderError(
					locationMessage: string,
					descriptionMessage: string
				) {
					panel.setAttribute(
						'aria-busy',
						'false'
					);

					if (state) {
						state.textContent =
							'暂不可用';
					}

					if (location) {
						location.textContent =
							locationMessage;
					}

					if (temperature) {
						temperature.textContent =
							'--';
					}

					if (description) {
						description.textContent =
							descriptionMessage;
					}

					if (icon) {
						icon.className =
							'ph ph-cloud-warning current-weather__icon';
					}

					if (high) {
						high.textContent = '--°';
					}

					if (low) {
						low.textContent = '--°';
					}

					if (updated) {
						updated.textContent =
							'更新失败';
					}

					if (retry) {
						retry.hidden = false;
					}
				}

				function renderWeather(
					locationData: IpLocationData,
					weatherData: CombinedWeatherData
				) {
					const realtime =
						weatherData.now
							.realtime?.[0];

					const weatherInfo =
						realtime?.infos;

					if (!weatherInfo) {
						throw new Error(
							'腾讯天气未返回实时天气数据'
						);
					}

					const range =
						getTemperatureRange(
							weatherData.future
						);

					panel.setAttribute(
						'aria-busy',
						'false'
					);

					if (state) {
						state.textContent =
							'LOCATION';
					}

					if (location) {
						location.textContent =
							formatLocation(
								locationData
							);
					}

					if (temperature) {
						temperature.textContent =
							typeof weatherInfo.temperature ===
							'number'
								? Math.round(
										weatherInfo.temperature
									).toString()
								: '--';
					}

					if (description) {
						const weatherText =
							weatherInfo.weather ||
							'天气状态未知';

						const windText = [
							weatherInfo.wind_direction,
							weatherInfo.wind_power_v2 ??
								weatherInfo.wind_power,
						]
							.filter(Boolean)
							.join(' ');

						const humidityText =
							typeof weatherInfo.humidity ===
							'number'
								? `湿度 ${weatherInfo.humidity}%`
								: '';

						description.textContent = [
							weatherText,
							windText,
							humidityText,
						]
							.filter(Boolean)
							.join(' · ');
					}

					if (icon) {
						icon.className =
							`ph ${getWeatherIcon(
								weatherInfo.weather
							)} current-weather__icon`;
					}

					if (high) {
						high.textContent =
							range.high === null
								? '--°'
								: `${Math.round(
										range.high
									)}°`;
					}

					if (low) {
						low.textContent =
							range.low === null
								? '--°'
								: `${Math.round(
										range.low
									)}°`;
					}

					if (updated) {
						const updateTime =
							formatUpdatedTime(
								realtime?.update_time ??
									weatherData.fetchedAt
							);

						updated.textContent =
							`Updated ${updateTime}`;
					}

					if (retry) {
						retry.hidden = true;
					}
				}

				async function loadWeather(
					forceRefresh = false
				) {
					resetView();

					if (!key) {
						renderError(
							'未配置腾讯地图 Key',
							'请设置 PUBLIC_TENCENT_MAP_KEY'
						);

						return;
					}

					if (forceRefresh) {
						window.localStorage.removeItem(
							LOCATION_CACHE_KEY
						);

						clearWeatherCaches();
						pendingLocation = null;
						pendingWeather.clear();
					}

					let locationData:
						| IpLocationData
						| undefined;

					try {
						locationData =
							await getIpLocation(
								key,
								forceRefresh
							);
					} catch (error) {
						console.error(
							'腾讯 IP 定位失败：',
							error
						);

						const message =
							error instanceof Error
								? error.message
								: '无法获取 IP 位置';

						renderError(
							'IP 定位失败',
							message
						);

						return;
					}

					const locationText =
						formatLocation(
							locationData
						);

					if (state) {
						state.textContent =
							'天气更新中';
					}

					if (location) {
						location.textContent =
							locationText;
					}

					/*
					 * 与前一次 IP 请求稍微错开，
					 * 降低连续请求触发频率限制的概率。
					 */
					await delay(REQUEST_GAP);

					try {
						const weatherData =
							await getWeather(
								key,
								locationData.adcode,
								forceRefresh
							);

						renderWeather(
							locationData,
							weatherData
						);
					} catch (error) {
						console.error(
							'腾讯天气请求失败：',
							error
						);

						const message =
							error instanceof Error
								? error.message
								: '无法加载天气数据';

						renderError(
							locationText,
							message
						);
					}
				}

				retry?.addEventListener(
					'click',
					() => {
						loadWeather(true);
					}
				);

				loadWeather();
			});
	}

	initializeWeatherPanels();

	document.addEventListener(
		'astro:page-load',
		initializeWeatherPanels
	);
</script>
