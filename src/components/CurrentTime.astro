<div class="current-time" aria-live="polite">
	<span class="current-time__label">当前时间</span>
	<time class="current-time__value" data-current-time datetime="">--:--:--</time>
</div>

<script>
	const timeElement = document.querySelector<HTMLTimeElement>('[data-current-time]');
	const formatter = new Intl.DateTimeFormat('zh-CN', {
		year: 'numeric',
		month: '2-digit',
		day: '2-digit',
		weekday: 'long',
		hour: '2-digit',
		minute: '2-digit',
		second: '2-digit',
	});

	const updateCurrentTime = () => {
		if (!timeElement) {
			return;
		}

		const now = new Date();
		timeElement.dateTime = now.toISOString();
		timeElement.textContent = formatter.format(now);
	};

	updateCurrentTime();
	window.setInterval(updateCurrentTime, 1000);
</script>

<style>
	.current-time {
		display: grid;
		width: fit-content;
		gap: var(--space-1);
		border-left: 2px solid var(--color-accent);
		padding: var(--space-2) 0 var(--space-2) var(--space-4);
	}

	.current-time__label {
		color: var(--color-muted);
		font-family: var(--font-mono);
		font-size: 0.78rem;
		font-weight: 700;
		text-transform: uppercase;
	}

	.current-time__value {
		color: var(--color-text);
		font-family: var(--font-mono);
		font-size: clamp(1.05rem, 2vw, 1.35rem);
		font-weight: 700;
	}
</style>
