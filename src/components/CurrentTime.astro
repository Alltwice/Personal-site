<div class="current-time">
	<span class="current-time__label">Local time / 浏览器时间</span>
	<time data-current-time datetime="">
		<span class="current-time__date" data-current-date>----.--.--</span>
		<span class="current-time__clock" data-current-clock>-- : -- : --</span>
	</time>
</div>

<script>
	const timeElement = document.querySelector<HTMLTimeElement>('[data-current-time]');
	const dateElement = timeElement?.querySelector<HTMLElement>('[data-current-date]');
	const clockElement = timeElement?.querySelector<HTMLElement>('[data-current-clock]');
	const dateFormatter = new Intl.DateTimeFormat('zh-CN', {
		year: 'numeric',
		month: '2-digit', day: '2-digit', weekday: 'short',
	});
	const clockFormatter = new Intl.DateTimeFormat('zh-CN', {
		hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false,
	});

	const updateCurrentTime = () => {
		if (!timeElement || !dateElement || !clockElement) return;

		const now = new Date();
		timeElement.dateTime = now.toISOString();
		dateElement.textContent = dateFormatter.format(now).replaceAll('/', '.');
		clockElement.textContent = clockFormatter.format(now).replaceAll(':', ' : ');
	};

	updateCurrentTime();
	window.setInterval(updateCurrentTime, 1000);
</script>
