---
import TagList from './TagList.astro';

const { post, variant = 'card', category } = Astro.props;
---

<a
	class:list={['post-card', variant === 'row' && 'post-card--row']}
	href={`/blog/${post.slug}`}
	data-date={post.date}
	data-views={post.views}
	data-category={category}
>
	<div class="post-card__meta">
		<time datetime={post.date}>{post.date}</time>
		<span>{post.views.toLocaleString('zh-CN')} views</span>
	</div>
	<div class="post-card__body">
		<h3>{post.title}</h3>
		<p>{post.excerpt}</p>
	</div>
	<TagList tags={post.tags} />
</a>

<style>
	.post-card {
		--tag-list-margin: auto 0 0;
		position: relative;
		display: flex;
		min-height: 240px;
		flex-direction: column;
		gap: var(--space-3);
		padding: var(--space-5);
		border: 1px solid var(--color-line);
		border-radius: var(--radius-small);
		background: var(--color-surface);
		color: var(--color-text);
		transition:
			transform var(--motion-fast) ease,
			box-shadow var(--motion-fast) ease,
			border-color var(--motion-fast) ease,
			background var(--motion-fast) ease;
	}

	.post-card::before {
		position: absolute;
		top: -1px;
		right: -1px;
		width: 24px;
		height: 2px;
		background: var(--color-accent);
		content: '';
		transform: scaleX(0);
		transform-origin: right;
		transition: transform var(--motion-fast) ease;
	}

	.post-card:hover {
		transform: translateY(-4px);
		border-color: var(--color-accent);
		background: var(--color-surface-raised);
		box-shadow: var(--shadow-card);
	}

	.post-card:hover::before {
		transform: scaleX(1);
	}

	.post-card h3 {
		font-size: 1.24rem;
		line-height: 1.25;
	}

	.post-card__body {
		display: grid;
		gap: var(--space-3);
	}

	.post-card p {
		color: var(--color-muted);
	}

	.post-card__meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-2);
		color: var(--color-muted);
		font-family: var(--font-mono);
		font-size: 0.76rem;
	}

	.post-card__meta span {
		color: var(--color-accent);
	}

	.post-card--row {
		--tag-list-margin: 0;
		display: grid;
		min-height: 164px;
		grid-template-columns: minmax(118px, 0.24fr) minmax(260px, 1fr) minmax(150px, 0.32fr);
		align-items: center;
		gap: clamp(var(--space-4), 3vw, var(--space-7));
	}

	.post-card--row .post-card__meta {
		align-self: stretch;
		flex-direction: column;
		align-items: flex-start;
		justify-content: center;
		border-right: 1px solid var(--color-line);
	}

	.post-card--row :global(.tag-list) {
		align-content: center;
		align-self: stretch;
		border-left: 1px solid var(--color-line);
		padding-left: var(--space-5);
	}

	@media (max-width: 760px) {
		.post-card--row {
			display: flex;
			min-height: 230px;
		}

		.post-card--row .post-card__meta {
			width: 100%;
			align-self: auto;
			flex-direction: row;
			justify-content: space-between;
			border-right: 0;
		}

		.post-card--row :global(.tag-list) {
			align-self: auto;
			border-left: 0;
			padding-left: 0;
		}
	}
</style>
