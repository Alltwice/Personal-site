---
import TagList from './TagList.astro';

const { project } = Astro.props;
---

<a class="project-card" href={`/projects/${project.slug}`}>
	<div class="project-card__topline">
		<span>{project.status}</span>
	</div>
	<h3>{project.name}</h3>
	<p>{project.summary}</p>
	<TagList tags={project.tags} />
</a>

<style>
	.project-card {
		--tag-list-margin: auto 0 0;
		position: relative;
		display: flex;
		min-height: var(--project-card-min-height, 240px);
		flex-direction: column;
		gap: var(--space-3);
		padding: var(--space-5);
		border: 1px solid var(--color-line);
		border-radius: var(--radius-small);
		background: var(--color-surface);
		color: var(--color-text);
		transition:
			transform var(--motion-fast) ease,
			box-shadow var(--motion-fast) ease,
			border-color var(--motion-fast) ease,
			background var(--motion-fast) ease;
	}

	.project-card::before {
		position: absolute;
		top: -1px;
		right: -1px;
		width: 24px;
		height: 2px;
		background: var(--color-accent);
		content: '';
		transform: scaleX(0);
		transform-origin: right;
		transition: transform var(--motion-fast) ease;
	}

	.project-card:hover {
		transform: var(--project-card-hover-transform, translateY(-4px));
		border-color: var(--color-accent);
		background: var(--color-surface-raised);
		box-shadow: var(--shadow-card);
	}

	.project-card:hover::before {
		transform: scaleX(1);
	}

	.project-card h3 {
		font-size: 1.24rem;
		line-height: 1.25;
	}

	.project-card p {
		color: var(--color-muted);
	}

	.project-card__topline {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-2);
		color: var(--color-muted);
		font-family: var(--font-mono);
		font-size: 0.76rem;
	}

	.project-card__topline span {
		color: var(--color-status);
		font-weight: 700;
	}
</style>
