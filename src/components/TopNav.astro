---
const { currentPath = '/' } = Astro.props;

const items = [
	{ href: '/', label: '主页', icon: 'ph-house-line' },
	{ href: '/blog', label: '文章', icon: 'ph-article' },
	{ href: '/projects', label: '项目', icon: 'ph-folder' },
	{ href: '/about', label: '关于', icon: 'ph-user' },
];

const isCurrent = (href: string) =>
	href === '/' ? currentPath === '/' : currentPath === href || currentPath.startsWith(`${href}/`);
---

<header class="top-nav" data-top-nav>
	<a class="top-nav__brand" href="/" aria-label="返回主页">
		<span class="top-nav__brand-mark" aria-hidden="true"></span>
		<span class="top-nav__brand-copy"><strong>Kristen.LOG</strong><small>PERSONAL LOG</small></span>
	</a>

	<button
		class="top-nav__toggle"
		type="button"
		aria-expanded="false"
		aria-controls="primary-navigation"
		data-nav-toggle
	>
		<span data-menu-label>菜单</span>
	</button>

	<nav id="primary-navigation" class="top-nav__links" aria-label="主导航" data-nav-menu>
		{items.map((item) => (
			<a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>
				<i class={`ph ${item.icon}`} aria-hidden="true"></i>
				<span>{item.label}</span>
			</a>
		))}
	</nav>
</header>

<script>
	let topNavController: AbortController | undefined;
	let scrollFrame = 0;

	function initializeTopNav() {
		topNavController?.abort();
		window.cancelAnimationFrame(scrollFrame);
		scrollFrame = 0;

		const nav =
			document.querySelector<HTMLElement>('[data-top-nav]');

		if (!nav) return;

		const controller = new AbortController();
		const { signal } = controller;
		topNavController = controller;

		const toggle =
			nav.querySelector<HTMLButtonElement>('[data-nav-toggle]');
		const menu =
			nav.querySelector<HTMLElement>('[data-nav-menu]');
		const label =
			nav.querySelector<HTMLElement>('[data-menu-label]');
		const detail =
			document.querySelector<HTMLElement>('.detail-stack');

		const setOpen = (open: boolean) => {
			if (!toggle || !label) return;
			nav.classList.toggle('is-open', open);
			toggle.setAttribute('aria-expanded', String(open));
			label.textContent = open ? '关闭' : '菜单';
		};

		const updateVisibility = () => {
			scrollFrame = 0;
			if (!detail) return;

			const hidden =
				detail.getBoundingClientRect().top <= 0;
			nav.classList.toggle('is-hidden', hidden);
			nav.toggleAttribute('inert', hidden);
			nav.setAttribute('aria-hidden', String(hidden));
			if (hidden) setOpen(false);
		};

		const requestVisibilityUpdate = () => {
			if (scrollFrame) return;
			scrollFrame =
				window.requestAnimationFrame(updateVisibility);
		};

		toggle?.addEventListener(
			'click',
			() => {
				setOpen(
					toggle.getAttribute('aria-expanded') !==
						'true'
				);
			},
			{ signal }
		);

		menu?.querySelectorAll('a').forEach((link) => {
			link.addEventListener(
				'click',
				() => setOpen(false),
				{ signal }
			);
		});

		document.addEventListener(
			'keydown',
			(event) => {
				if (event.key === 'Escape') {
					setOpen(false);
					toggle?.focus();
				}
			},
			{ signal }
		);

		window
			.matchMedia('(min-width: 761px)')
			.addEventListener(
				'change',
				(event) => {
					if (event.matches) setOpen(false);
				},
				{ signal }
			);

		if (detail) {
			updateVisibility();
			window.addEventListener(
				'scroll',
				requestVisibilityUpdate,
				{ passive: true, signal }
			);
			window.addEventListener(
				'resize',
				requestVisibilityUpdate,
				{ signal }
			);
		}
	}

	initializeTopNav();
	document.addEventListener('astro:page-load', initializeTopNav);
</script>
